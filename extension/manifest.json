{
  "manifest_version": 3,
  "name": "FakeScope",
  "version": "0.1.0",
  "description": "Score news article credibility with a local LLM, Wayback history, domain reputation, and community votes.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "FakeScope",
    "default_icon": {
      "16": "icons/fakescope-icon16.png",
      "32": "icons/fakescope-icon32.png",
      "48": "icons/fakescope-icon48.png",
      "64": "icons/fakescope-icon64.png"
    }
  },
  "icons": {
    "16": "icons/fakescope-icon16.png",
    "32": "icons/fakescope-icon32.png",
    "48": "icons/fakescope-icon48.png",
    "64": "icons/fakescope-icon64.png",
    "128": "icons/fakescope-icon128.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "<all_urls>"]
}
